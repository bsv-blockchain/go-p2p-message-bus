# ================================================================================================
# 🎯 PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-p2p-message-bus
# Load Order: 90 (loaded last before 99-local.env, overrides all defaults)
#
# This file contains project-specific settings that override defaults from earlier env files:
# - Coverage provider and exclusions
# - CVE exclusion lists for known acceptable vulnerabilities
#
# ================================================================================================

# ================================================================================================
# 🔧 GO VERSION (must match go.mod requirement)
# ================================================================================================

# Override base config (00-core.env) to match go.mod "go 1.25" requirement.
# Running 1.24.x against a go 1.25 module causes toolchain-switching mid-test,
# which makes "go tool covdata" unavailable and breaks coverage artifact upload.
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER
# ================================================================================================

# Coverage Provider Selection (overrides 10-coverage.env default of "internal")
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration (only used when provider=codecov)
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS (matching codecov.yml ignore paths)
# ================================================================================================

GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,cmd/,examples/,mocks/,testing/

# ================================================================================================
# 🛡️ CVE EXCLUSIONS
# ================================================================================================

# Custom exclusions for Nancy vulnerability scanning
# CVE-2024-38513: (libp2p related)
# CVE-2023-45142: (libp2p related)
# CVE-2025-64702: quic-go@v0.55.0
# CVE-2021-43668: (libp2p related)
# CVE-2023-26248: (libp2p related)
# CVE-2026-26014 for github.com/pion/dtls/v2@v2.2.12
#   Information Exposure (CWE-200) - Random nonce generation with GCM ciphers
#   Affects: pion/dtls/v2 v1.0.0 through v2.2.12 (v2.2.12 is latest in v2 branch)
#   Fixed in: pion/dtls/v3@v3.1.0+ (we have v3.1.1, which is safe)
#   Dependency path: go-p2p-message-bus → go-libp2p@v0.47.0 → pion/webrtc/v4 → pion/dtls/v2
#   Status: Transitive dependency - cannot upgrade v2→v3 (different major versions)
#   Mitigation: v3.1.1 is already present for WebRTC functionality
#   Risk: Low - vulnerability in legacy v2 branch, safe v3 branch in use
#   Monitoring: Track go-libp2p releases for removal of v2 dependency
NANCY_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-26014,CVE-2025-65637,CVE-2026-33809,CVE-2026-39882,CVE-2026-39883,CVE-2026-33186

# Govulncheck/Magex CVE Exclusions (same as Nancy)
MAGE_X_CVE_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-26014,CVE-2025-65637,CVE-2026-33809,CVE-2026-39882,CVE-2026-39883,CVE-2026-33186
